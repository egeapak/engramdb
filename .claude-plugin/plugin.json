{
  "name": "engramdb",
  "version": "0.3.0",
  "description": "Project-scoped persistent memory store for coding agents. Stores decisions, hazards, conventions, and context about the codebase.",
  "mcpServers": {
    "memory": {
      "command": "engramdb",
      "args": ["serve", "--dir", "."],
      "env": {}
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "engramdb hook pre-tool-use --dir ."
          }
        ]
      }
    ]
  }
}
